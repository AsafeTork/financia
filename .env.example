VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...
# Chave publicavel da Stripe (pk_...). Habilita o checkout in-app (Stripe Elements).
# A chave secreta (sk_...) fica SO no Supabase (Edge Function secrets), nunca no front.
# O codigo aceita qualquer um dos dois nomes abaixo (use apenas um):
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_ou_pk_test_...
# VITE_STRIPE_PUBLIC_KEY=pk_live_ou_pk_test_...
